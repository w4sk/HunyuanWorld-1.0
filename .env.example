# Copy to .env and fill in your Hugging Face access token.
#   cp .env.example .env
# Token: https://huggingface.co/settings/tokens  (read scope is enough)
# You MUST also accept the licenses on these gated repos with the same account:
#   - https://huggingface.co/black-forest-labs/FLUX.1-dev
#   - https://huggingface.co/black-forest-labs/FLUX.1-Fill-dev
#   - https://huggingface.co/tencent/HunyuanWorld-1
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Where the ~90GB of model weights live (and download to) ----
# HuggingFace downloads weights straight into this cache, and reads them from it
# on later runs — so this is BOTH the download destination and the store.
# Leave unset to use the local cache (~/.cache/huggingface).
# For a shared NAS, point it at an NFS mount; first run downloads onto the NAS,
# other servers then just read from it (no re-download).
# HF_CACHE_DIR=/mnt/ai-models/huggingface

# Optional: ZIM checkpoints location (defaults to the in-repo ZIM/zim_vit_l_2092).
# ZIM_DIR=/mnt/ai-models/zim/zim_vit_l_2092

# Set to 1 once weights are pre-staged on a read-only/NFS cache: skips network
# and lock checks at load time (robust + faster for multi-server prod).
# HF_HUB_OFFLINE=1
